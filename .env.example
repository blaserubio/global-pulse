# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://globalpulse:globalpulse@localhost:5432/globalpulse

# Redis
REDIS_URL=redis://localhost:6379

# News API Keys
NEWSAPI_KEY=your_newsapi_key_here
GNEWS_KEY=your_gnews_key_here
MEDIASTACK_KEY=your_mediastack_key_here

# Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Ingestion
INGESTION_INTERVAL_MINUTES=15
RSS_TIMEOUT_MS=20000
RSS_MAX_ITEMS=20

# Clustering
CLUSTERING_SIMILARITY_THRESHOLD=0.90
EMBEDDING_BATCH_SIZE=50

# Admin (generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# Error Monitoring (optional)
SENTRY_DSN=

# Logging (optional)
LOGTAIL_TOKEN=
LOG_LEVEL=info
